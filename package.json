{
  "name": "@wc-toolkit/cem-analyzer-plugin",
  "version": "1.0.1",
  "description": "Vite/Rollup/Webpack plugins to run Custom Elements Manifest Analyzer",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./vite": {
      "types": "./dist/vite.d.ts",
      "default": "./dist/vite.js"
    },
    "./webpack": {
      "types": "./dist/webpack.d.ts",
      "default": "./dist/webpack.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/vite.ts src/webpack.ts --format esm,cjs --dts",
    "demo": "pnpm --filter cem-analyzer-plugin-demo run build",
    "format": "oxfmt .",
    "lint": "oxlint src",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "changeset": "changeset",
    "release": "pnpm run build && changeset publish"
  },
  "keywords": [
    "vite",
    "rollup",
    "rolldown",
    "webpack",
    "custom-elements-manifest",
    "cem"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wc-toolkit/cem-analyzer-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/wc-toolkit/cem-analyzer-plugin/issues"
  },
  "homepage": "https://wc-toolkit.com/cem-utilities/cem-analyzer-plugin",
  "peerDependencies": {
    "@custom-elements-manifest/analyzer": ">=0.9.0"
  },
  "dependencies": {
    "execa": "^9.6.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.16.0",
    "husky": "^9.1.7",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vite": ">=5.0.0",
    "webpack": "^4.0.0 || ^5.0.0"
  },
  "lint-staged": {
    "*.ts": "eslint --cache --fix",
    "*.--write": "prettier --write"
  },
  "publishConfig": {
    "provenance": true,
    "access": "public"
  }
}
